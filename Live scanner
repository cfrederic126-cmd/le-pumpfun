<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CryptoRescue — Scanner Live</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: #060A14; color: #E8EAF0; font-family: Inter, system-ui, sans-serif; min-height: 100vh; }
.header { background: #0A0E1A; border-bottom: 1px solid #1E2535; padding: 16px 24px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.logo { width: 36px; height: 36px; background: linear-gradient(135deg, #3B82F6, #8B5CF6); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
.logo.live { background: linear-gradient(135deg, #10B981, #3B82F6); }
.title { font-size: 16px; font-weight: 700; }
.subtitle { font-size: 11px; color: #6B7280; }
.subtitle.live { color: #10B981; }
.networks { margin-left: auto; display: flex; gap: 8px; flex-wrap: wrap; }
.net-btn { padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 600; cursor: pointer; border: 1px solid; transition: all 0.2s; background: none; color: inherit; }
