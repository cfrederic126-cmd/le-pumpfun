function now() { return new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit',second:'2-digit'}); }
function fmtMC(n) {
  if (!n) return '$0';
  if (n >= 1000000) return '$'+(n/1000000).toFixed(2)+'M';
  if (n >= 1000) return '$'+(n/1000).toFixed(1)+'K';
  return '$'+Math.round(n);
}
function short(a) { return a ? a.slice(0,6)+'…'+a.slice(-4) : '—'; }

function getStatus(mc) {
  if (mc >= GRAD_MC) return 'graduated';
  if (mc >= APPROACH_MC) return 'approaching';
  if (mc >= WATCH_MC) return 'watching';
  return null;
}

